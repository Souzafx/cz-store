# ==========================================================
# CZ Store Backend — Configuração
# ==========================================================
# Copie este arquivo para ".env" e preencha conforme o ambiente.
# ==========================================================

# ---- Ambiente ----
# development | production
NODE_ENV=development

# ---- Modo ----
# true  = simulação (sem chamar Shopee real)
# false = live (precisa das credenciais abaixo)
MOCK_MODE=true

# ---- Servidor ----
PORT=3000
# Por padrão só aceita conexões da própria máquina (localhost).
# Para expor na rede ou em cloud: BIND_HOST=0.0.0.0
BIND_HOST=127.0.0.1

# ---- Segurança ----
# Token que o frontend deve enviar no header X-CZ-Token.
# Se vazio, a autenticação por token fica desabilitada (só OK em localhost).
# Gere um forte com: openssl rand -hex 32
CZ_API_TOKEN=

# ---- Rate limit ----
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# ---- CORS ----
# Lista de origens permitidas, separadas por vírgula.
# localhost já é permitido por padrão. Exemplo:
# ALLOWED_ORIGINS=https://meusite.com,https://admin.meusite.com
ALLOWED_ORIGINS=

# ---- Logs ----
# error | warn | info | debug
LOG_LEVEL=info

# ==========================================================
# Shopee Partner API
# ==========================================================
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=

# Tokens iniciais (opcional — fluxo OAuth cria automaticamente
# e salva em data/shopee-tokens.json).
SHOPEE_ACCESS_TOKEN=
SHOPEE_REFRESH_TOKEN=

# Base URL:
# - Produção: https://partner.shopeemobile.com
# - Sandbox:  https://partner.test-stable.shopeemobile.com
SHOPEE_BASE_URL=https://partner.shopeemobile.com
