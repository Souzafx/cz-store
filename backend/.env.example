# ==========================================================
# Configuração do backend CZ Store — Integração com Shopee
# ==========================================================
# Copie este arquivo para ".env" e preencha as credenciais.
# Enquanto MOCK_MODE=true, as credenciais são ignoradas e o
# backend simula respostas da Shopee (útil para desenvolvimento).
# ==========================================================

# Porta do servidor local
PORT=3000

# Modo simulação — quando true, não chama a API real da Shopee.
# Defina false quando tiver todas as credenciais preenchidas.
MOCK_MODE=true

# ---- Credenciais da Shopee Partner API ----
# Obtidas no painel: https://partner.shopeemobile.com/
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=

# Access token obtido via OAuth (fluxo separado — ver README).
# Expira periodicamente; precisa ser renovado.
SHOPEE_ACCESS_TOKEN=

# URL base da API. Para sandbox/teste use partner.test-stable.shopeemobile.com
SHOPEE_BASE_URL=https://partner.shopeemobile.com
